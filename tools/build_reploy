#!/usr/bin/env python3
from __future__ import annotations

import argparse
from datetime import datetime
import os
import platform
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


@dataclass(frozen=True)
class Target:
    goos: str
    goarch: str

    @property
    def label(self) -> str:
        return f"{self.goos}-{self.goarch}"

    @property
    def binary_name(self) -> str:
        if self.goos == "windows":
            return "reploy.exe"
        return "reploy"


DEFAULT_TARGETS = (
    Target("linux", "amd64"),
    Target("linux", "arm64"),
    Target("darwin", "amd64"),
    Target("darwin", "arm64"),
    Target("windows", "amd64"),
    Target("windows", "arm64"),
)

ACTIVE_TARGET_LABELS = {target.label for target in DEFAULT_TARGETS}


def current_target() -> Target | None:
    goos_by_platform = {
        "darwin": "darwin",
        "linux": "linux",
        "win32": "windows",
        "cygwin": "windows",
        "msys": "windows",
    }
    goarch_by_machine = {
        "amd64": "amd64",
        "x86_64": "amd64",
        "aarch64": "arm64",
        "arm64": "arm64",
    }
    goos = goos_by_platform.get(sys.platform)
    goarch = goarch_by_machine.get(platform.machine().lower())
    if goos is None or goarch is None:
        return None
    return Target(goos, goarch)


def parse_target(value: str) -> Target:
    parts = value.split("-")
    if len(parts) != 2 or not all(parts):
        raise argparse.ArgumentTypeError(
            f"invalid target {value!r}; expected GOOS-GOARCH, such as linux-amd64"
        )
    return Target(parts[0], parts[1])


def run(
    command: list[str],
    *,
    cwd: Path,
    env: dict[str, str] | None,
    verbose: bool,
) -> None:
    if verbose:
        display_env = ""
        if env is not None:
            display_env = " ".join(
                f"{name}={value}"
                for name, value in sorted(env.items())
                if name in {"GOOS", "GOARCH", "CGO_ENABLED"}
            )
        prefix = f"{display_env} " if display_env else ""
        print(f"+ {prefix}{' '.join(command)}", flush=True)
        subprocess.run(command, cwd=cwd, env=env, check=True)
        return

    result = subprocess.run(
        command,
        cwd=cwd,
        env=env,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="", file=sys.stderr)
        raise subprocess.CalledProcessError(result.returncode, command)


def default_go_cache() -> str:
    return os.environ.get("GOCACHE", "/tmp/reploy-go-cache")


def reploy_version(root: Path) -> str:
    version = os.environ.get("REPLOY_VERSION", "").strip()
    if version:
        return version
    version_file = root / "VERSION"
    version = version_file.read_text(encoding="utf-8").strip()
    if not version:
        raise ValueError(f"could not read Reploy version from {version_file}")
    return version


def is_development_version(version: str) -> bool:
    return "dev" in version.strip().lower()


def source_control_output(root: Path, *args: str) -> str:
    if shutil.which("sl") is None:
        return ""
    result = subprocess.run(
        ["sl", *args],
        cwd=root,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    if result.returncode != 0:
        return ""
    return result.stdout.strip()


def source_control_dirty(root: Path) -> bool:
    if shutil.which("sl") is None:
        return False
    result = subprocess.run(
        ["sl", "status"],
        cwd=root,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    return result.returncode == 0 and result.stdout.strip() != ""


def source_commit(root: Path) -> str:
    for name in ("REPLOY_COMMIT", "GITHUB_SHA"):
        commit = os.environ.get(name, "").strip()
        if commit:
            return commit[:10]
    commit = source_control_output(root, "log", "-r", ".", "-T", "{node}\n")
    return commit[:10]


def build_timestamp() -> str:
    timestamp = datetime.now().astimezone().replace(microsecond=0)
    timezone_name = timestamp.strftime("%Z") or timestamp.strftime("%z")
    return f"{timestamp:%Y-%m-%d %H:%M:%S} {timezone_name}".strip()


def ldflag_safe_timestamp(timestamp: str) -> str:
    return "_".join(timestamp.split())


def dev_build_ldflags(root: Path, version: str) -> list[str]:
    if not is_development_version(version):
        return []

    commit = source_commit(root)

    dirty = os.environ.get("REPLOY_DIRTY", "").strip()
    if not dirty:
        dirty = "true" if source_control_dirty(root) else "false"

    timestamp = os.environ.get("REPLOY_BUILD_TIMESTAMP", "").strip()
    if not timestamp:
        timestamp = build_timestamp()
    timestamp = ldflag_safe_timestamp(timestamp)

    ldflags = []
    if commit:
        ldflags.append(f"-X github.com/omry/reploy.BuildCommit={commit}")
    ldflags.append(f"-X github.com/omry/reploy.BuildDirty={dirty}")
    ldflags.append(f"-X github.com/omry/reploy.BuildTimestamp={timestamp}")
    return ldflags


def display_path(path: Path, *, root: Path) -> str:
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def parse_args() -> argparse.Namespace:
    root = Path(__file__).resolve().parents[1]
    parser = argparse.ArgumentParser(description="Build the Reploy Go binary.")
    parser.add_argument(
        "--root",
        type=Path,
        default=root,
        help=f"repository root, default {root}",
    )
    parser.add_argument(
        "--outdir",
        type=Path,
        default=Path("dist"),
        help="output directory, default ROOT/dist",
    )
    parser.add_argument(
        "--target",
        action="append",
        type=parse_target,
        metavar="GOOS-GOARCH",
        help=(
            "build one target, such as linux-amd64; may be passed more than once. "
            "Defaults to the current platform."
        ),
    )
    parser.add_argument(
        "--all",
        action="store_true",
        help="build all active release targets",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="remove the output directory before building",
    )
    parser.add_argument(
        "--test",
        action="store_true",
        help="run Reploy Go tests before building",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="show commands as they run",
    )
    parser.add_argument(
        "--debug",
        action="store_true",
        help="include debug symbols instead of stripping release binaries",
    )
    return parser.parse_args()


def selected_targets(args: argparse.Namespace) -> tuple[Target, ...]:
    if args.all and args.target:
        raise ValueError("--all cannot be combined with --target")
    if args.all:
        return DEFAULT_TARGETS
    if args.target:
        targets = tuple(args.target)
        unsupported = [
            target.label for target in targets if target.label not in ACTIVE_TARGET_LABELS
        ]
        if unsupported:
            raise ValueError(
                "unsupported build target(s): "
                + ", ".join(unsupported)
                + "; active targets: "
                + ", ".join(sorted(ACTIVE_TARGET_LABELS))
            )
        return targets
    target = current_target()
    if target is None:
        raise ValueError("could not infer current target; pass --target or --all")
    if target.label not in ACTIVE_TARGET_LABELS:
        raise ValueError(
            f"current target {target.label} is not active; pass one of: "
            + ", ".join(sorted(ACTIVE_TARGET_LABELS))
        )
    return (target,)


def build_targets(
    *,
    root: Path,
    outdir: Path,
    targets: tuple[Target, ...],
    clean: bool,
    test: bool,
    strip: bool,
    verbose: bool,
) -> list[Path]:
    if not (root / "go.mod").exists():
        raise FileNotFoundError(f"missing Reploy module: {root / 'go.mod'}")
    if not (root / "cmd" / "reploy" / "main.go").exists():
        raise FileNotFoundError(
            f"missing Reploy command: {root / 'cmd' / 'reploy' / 'main.go'}"
        )
    if shutil.which("go") is None:
        raise FileNotFoundError("missing required executable: go")

    env = os.environ.copy()
    env.setdefault("GOCACHE", default_go_cache())
    Path(env["GOCACHE"]).mkdir(parents=True, exist_ok=True)
    version = reploy_version(root)

    if clean and outdir.exists():
        shutil.rmtree(outdir)
    outdir.mkdir(parents=True, exist_ok=True)

    if test:
        run(["go", "test", "./..."], cwd=root, env=env, verbose=verbose)

    built: list[Path] = []
    for target in targets:
        target_dir = outdir / target.label
        target_dir.mkdir(parents=True, exist_ok=True)
        output = target_dir / target.binary_name
        target_env = env.copy()
        target_env.update(
            {
                "CGO_ENABLED": "0",
                "GOOS": target.goos,
                "GOARCH": target.goarch,
            }
        )
        command = [
            "go",
            "build",
            "-buildvcs=false",
            "-trimpath",
        ]
        ldflags = [f"-X github.com/omry/reploy.Version={version}"]
        ldflags.extend(dev_build_ldflags(root, version))
        if strip:
            ldflags.extend(["-s", "-w"])
        command.extend(["-ldflags", " ".join(ldflags)])
        command.extend(["-o", str(output), "./cmd/reploy"])
        run(command, cwd=root, env=target_env, verbose=verbose)
        built.append(output)
        print(f"built {display_path(output, root=root)}")
    return built


def main() -> int:
    args = parse_args()
    root = args.root.resolve()
    outdir = args.outdir
    if not outdir.is_absolute():
        outdir = root / outdir

    try:
        build_targets(
            root=root,
            outdir=outdir,
            targets=selected_targets(args),
            clean=args.clean,
            test=args.test,
            strip=not args.debug,
            verbose=args.verbose,
        )
    except (OSError, ValueError, subprocess.CalledProcessError) as exc:
        print(f"build_reploy: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
