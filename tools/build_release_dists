#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path


REPLOY_TARGETS = (
    "linux-amd64",
    "linux-arm64",
    "darwin-amd64",
    "darwin-arm64",
    # Formal Windows support is deferred.
    # "windows-amd64",
    # "windows-arm64",
)


def _run(
    command: list[str],
    *,
    verbose: bool,
    env: dict[str, str] | None = None,
) -> None:
    if verbose:
        subprocess.run(command, check=True, env=env)
        return

    result = subprocess.run(
        command,
        check=False,
        text=True,
        capture_output=True,
        env=env,
    )
    if result.returncode != 0:
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="", file=sys.stderr)
        raise subprocess.CalledProcessError(result.returncode, command)


def _reploy_version(root: Path) -> str:
    version = (root / "VERSION").read_text(encoding="utf-8").strip()
    if not version:
        raise ValueError(f"missing Reploy version in {root / 'VERSION'}")
    return version


def _binary_name(target: str) -> str:
    if target.startswith("windows-"):
        return "reploy.exe"
    return "reploy"


def build_distributions(
    *,
    root: Path,
    outdir: Path,
    clean: bool,
    no_isolation: bool,
    verbose: bool,
) -> None:
    version = _reploy_version(root)
    if clean and outdir.exists():
        shutil.rmtree(outdir)
    outdir.mkdir(parents=True, exist_ok=True)

    print("build: Reploy binaries")
    _run(
        [
            str(root / "tools" / "build_reploy"),
            "--root",
            str(root),
            "--outdir",
            str(outdir),
            "--all",
            "--clean",
        ],
        verbose=verbose,
    )

    python_package = root / "packaging" / "python"
    for target in REPLOY_TARGETS:
        print(f"build: reploy {target} wheel")
        env = os.environ.copy()
        env.update(
            {
                "REPLOY_VERSION": version,
                "REPLOY_TARGET": target,
                "REPLOY_BINARY": str(outdir / target / _binary_name(target)),
            }
        )
        command = [
            sys.executable,
            "-m",
            "build",
            "--wheel",
            "--outdir",
            str(outdir),
        ]
        if no_isolation:
            command.append("--no-isolation")
        command.append(str(python_package))
        _run(
            command,
            verbose=verbose,
            env=env,
        )


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Build Reploy release distributions.")
    parser.add_argument("--root", default=".", help=argparse.SUPPRESS)
    parser.add_argument(
        "--outdir",
        default="dist",
        help="directory for built distributions, default: dist",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="remove the output directory before building",
    )
    parser.add_argument(
        "--no-isolation",
        action="store_true",
        help="build wheels using the current Python environment",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="show detailed output from python -m build",
    )
    namespace = parser.parse_args(argv)

    try:
        build_distributions(
            root=Path(namespace.root).resolve(),
            outdir=Path(namespace.outdir).resolve(),
            clean=namespace.clean,
            no_isolation=namespace.no_isolation,
            verbose=namespace.verbose,
        )
    except (OSError, subprocess.CalledProcessError, ValueError) as exc:
        print(f"build_release_dists: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
