#!/usr/bin/env python3
"""Exercise the Reploy CLI against a real temporary deployment."""

from __future__ import annotations

import argparse
import codecs
import os
import re
import shutil
import socket
import subprocess
import sys
import tempfile
import threading
from pathlib import Path
from typing import NamedTuple

ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
INTERRUPT_EXIT_CODE = 130


class StreamCapture(NamedTuple):
    stdout_chunks: list[str]
    stderr_chunks: list[str]
    threads: list[threading.Thread]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--reploy",
        required=True,
        help="Path to the reploy binary to exercise.",
    )
    parser.add_argument(
        "--keep-workdir",
        action="store_true",
        help="Keep the temporary smoke work directory for debugging.",
    )
    parser.add_argument(
        "--color",
        action="store_true",
        help="Force color output and use a smart terminal identity.",
    )
    parser.add_argument(
        "--plan-only",
        action="store_true",
        help=(
            "Skip the Docker-backed bundle build/check/list-all while still "
            "running preinstall and install dry-run checks."
        ),
    )
    parser.add_argument(
        "--no-docker",
        action="store_true",
        help="Exercise staging and bundle planning without executing Docker, preinstall, or install checks.",
    )
    parser.add_argument(
        "--runtime",
        action="store_true",
        help="Include the live staging runtime lifecycle: up/status/logs/test/down.",
    )
    parser.add_argument(
        "--persistent-install",
        action="store_true",
        help="Include Docker-managed persistent install/control/uninstall checks.",
    )
    parser.add_argument(
        "--docker-mode",
        choices=("required", "optional", "skip"),
        default="required",
        help="Control Docker-backed smoke phases. Defaults to required.",
    )
    args = parser.parse_args()
    if args.no_docker:
        if args.docker_mode != "required":
            parser.error("--no-docker cannot be combined with --docker-mode")
        args.docker_mode = "skip"
    if args.runtime and args.plan_only:
        parser.error("--runtime cannot be combined with --plan-only")
    if args.runtime and args.docker_mode != "required":
        parser.error("--runtime requires Docker and cannot be combined with --no-docker or optional Docker mode")
    if args.persistent_install and args.plan_only:
        parser.error("--persistent-install cannot be combined with --plan-only")
    if args.persistent_install and args.docker_mode != "required":
        parser.error(
            "--persistent-install requires Docker and cannot be combined "
            "with --no-docker or optional Docker mode"
        )
    return args


def run(argv: list[str], *, cwd: Path, env: dict[str, str]) -> subprocess.CompletedProcess[str]:
    print("+ " + " ".join(argv), flush=True)
    completed = subprocess.Popen(
        argv,
        cwd=cwd,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    stdout_chunks: list[str] = []
    stderr_chunks: list[str] = []
    output_lock = threading.Lock()

    def safe_write(target, content: str) -> None:
        try:
            target.write(content)
            target.flush()
        except UnicodeEncodeError:
            encoding = getattr(target, "encoding", None) or "utf-8"
            buffer = getattr(target, "buffer", None)
            if buffer is None:
                target.write(content.encode(encoding, errors="replace").decode(encoding, errors="replace"))
                target.flush()
                return
            buffer.write(content.encode(encoding, errors="replace"))
            buffer.flush()

    def stream_pipe(pipe, target, chunks: list[str]) -> None:
        assert pipe is not None
        decoder = codecs.getincrementaldecoder("utf-8")(errors="replace")
        while True:
            data = pipe.read(1)
            if data == b"":
                break
            content = decoder.decode(data)
            if content == "":
                continue
            chunks.append(content)
            with output_lock:
                safe_write(target, content)
        remainder = decoder.decode(b"", final=True)
        if remainder:
            chunks.append(remainder)
            with output_lock:
                safe_write(target, remainder)

    threads = [
        threading.Thread(target=stream_pipe, args=(completed.stdout, sys.stdout, stdout_chunks)),
        threading.Thread(target=stream_pipe, args=(completed.stderr, sys.stderr, stderr_chunks)),
    ]
    for thread in threads:
        thread.start()
    capture = StreamCapture(stdout_chunks, stderr_chunks, threads)
    try:
        returncode = completed.wait()
    except KeyboardInterrupt:
        terminate_child(completed)
        join_streams(capture)
        raise SmokeInterrupted(f"interrupted while running: {' '.join(argv)}") from None
    join_streams(capture)
    if returncode != 0:
        raise SystemExit(f"[smoke] command failed with exit code {returncode}: {' '.join(argv)}")
    return subprocess.CompletedProcess(
        argv,
        returncode,
        stdout="".join(stdout_chunks),
        stderr="".join(stderr_chunks),
    )


class SmokeInterrupted(Exception):
    pass


def terminate_child(process: subprocess.Popen[bytes]) -> None:
    if process.poll() is not None:
        return
    process.terminate()
    try:
        process.wait(timeout=5)
    except subprocess.TimeoutExpired:
        process.kill()
        process.wait(timeout=5)


def join_streams(capture: StreamCapture) -> None:
    for thread in capture.threads:
        thread.join(timeout=5)


def require_contains(output: str, needle: str, context: str) -> None:
    if needle not in strip_ansi(output):
        raise SystemExit(f"[smoke] {context} did not contain {needle!r}\n--- output ---\n{output}")


def require_not_contains(output: str, needle: str, context: str) -> None:
    if needle in strip_ansi(output):
        raise SystemExit(f"[smoke] {context} unexpectedly contained {needle!r}\n--- output ---\n{output}")


def require_prefixed_lines(output: str, prefix: str, context: str) -> None:
    stripped = strip_ansi(output)
    unprefixed = [line for line in stripped.splitlines() if line.strip() and not line.startswith(prefix)]
    if unprefixed:
        detail = "\n".join(unprefixed[:5])
        raise SystemExit(
            f"[smoke] {context} contained unprefixed line(s); expected {prefix!r}\n"
            f"--- unprefixed ---\n{detail}\n--- output ---\n{output}"
        )


def strip_ansi(value: str) -> str:
    return ANSI_ESCAPE_RE.sub("", value)


def completed_output(completed: subprocess.CompletedProcess[str]) -> str:
    return completed.stdout + completed.stderr


def docker_available(env: dict[str, str], cwd: Path) -> tuple[bool, str]:
    if shutil.which("docker") is None:
        return False, "docker command not found"
    try:
        completed = subprocess.run(
            ["docker", "info"],
            cwd=cwd,
            env=env,
            text=True,
            encoding="utf-8",
            errors="replace",
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=20,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return False, "docker info timed out"
    if completed.returncode != 0:
        detail = (completed.stderr or completed.stdout).strip()
        if detail:
            return False, detail
        return False, f"docker info failed with exit code {completed.returncode}"
    return True, ""


def free_local_port() -> str:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as listener:
        listener.bind(("127.0.0.1", 0))
        return str(listener.getsockname()[1])


def install_scope() -> str:
    return "user"


def docker_managed_install() -> bool:
    return install_scope() == "user"


def control_script_command(install_dir: Path, *args: str) -> list[str]:
    if sys.platform.startswith(("win32", "cygwin", "msys")):
        script = install_dir / "smoke-appctl.ps1"
        return [
            "powershell",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            str(script),
            *args,
        ]
    return [str(install_dir / "smoke-appctl"), *args]


def update_env_file(path: Path, updates: dict[str, str]) -> None:
    lines = path.read_text().splitlines()
    remaining = dict(updates)
    rewritten: list[str] = []
    for line in lines:
        key, separator, _ = line.partition("=")
        if separator and key in remaining:
            rewritten.append(f"{key}={remaining.pop(key)}")
        else:
            rewritten.append(line)
    for key, value in remaining.items():
        rewritten.append(f"{key}={value}")
    path.write_text("\n".join(rewritten) + "\n")


def make_workdir() -> Path:
    return Path(tempfile.mkdtemp(prefix="reploy-e2e-smoke-"))


def run_runtime_smoke(reploy: Path, deploy_dir: Path, workdir: Path, env: dict[str, str]) -> None:
    host_port = free_local_port()
    update_env_file(
        deploy_dir / ".reploy" / "docker.env",
        {
            "REPLOY_HOST_BIND": "127.0.0.1",
            "REPLOY_HOST_PORT": host_port,
            "REPLOY_PORT_HTTPS_HOST_BIND": "127.0.0.1",
            "REPLOY_PORT_HTTPS_HOST_PORT": host_port,
            "REPLOY_PUBLIC_SCHEME": "https",
        },
    )

    primary_error: BaseException | None = None
    started = False
    try:
        app_check = run(
            [str(reploy), "app", "config", "check", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(app_check.stdout, '"check": "pass"', "config check")

        run([str(reploy), "up", "--dir", str(deploy_dir)], cwd=workdir, env=env)
        started = True

        run([str(reploy), "status", "--dir", str(deploy_dir)], cwd=workdir, env=env)
        health = run(
            [str(reploy), "test", "--timeout", "30s", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(health.stdout, f"ok: https://127.0.0.1:{host_port}/_health_", "health check")

        logs = run(
            [str(reploy), "logs", "--tail", "50", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(logs.stdout, "smoke-suite serving HTTPS", "runtime logs")

        live_check = run(
            [str(reploy), "app", "config", "check", "--live", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(live_check.stdout, '"check": "pass"', "live config check")
    except BaseException as error:
        primary_error = error
        raise
    finally:
        if started:
            try:
                run([str(reploy), "down", "--dir", str(deploy_dir)], cwd=workdir, env=env)
            except BaseException as cleanup_error:
                if primary_error is None:
                    raise
                print(f"[smoke] warning: runtime cleanup failed after earlier error: {cleanup_error}", file=sys.stderr)


def run_persistent_install_smoke(
    reploy: Path,
    deploy_dir: Path,
    install_dir: Path,
    workdir: Path,
    env: dict[str, str],
) -> None:
    install_port = free_local_port()
    installed = False
    try:
        install = run(
            [
                str(reploy),
                "install",
                "--dir",
                str(deploy_dir),
                "--to",
                str(install_dir),
                "--scope",
                install_scope(),
                "--port",
                install_port,
            ],
            cwd=workdir,
            env=env,
        )
        installed = True
        require_contains(install.stdout, f"server url: https://127.0.0.1:{install_port}", "install output")

        status = run(control_script_command(install_dir, "status"), cwd=workdir, env=env)
        require_contains(completed_output(status), "smoke-app", "installed control status")
        if docker_managed_install():
            require_contains(status.stdout, "[DEPLOYED : smoke-app] NAME", "installed control status")
        else:
            require_contains(completed_output(status), "[DEPLOYED : smoke-app]", "installed control status")
        require_not_contains(completed_output(status), "[smoke-app]", "installed control status")

        logs = run(control_script_command(install_dir, "logs"), cwd=workdir, env=env)
        require_contains(completed_output(logs), "smoke-suite serving HTTPS", "installed control logs")
        require_not_contains(completed_output(logs), "[smoke-app]", "installed control logs")

        live_check = run(control_script_command(install_dir, "config", "check", "--live"), cwd=workdir, env=env)
        require_contains(completed_output(live_check), '"check": "pass"', "installed live config check")
        require_not_contains(completed_output(live_check), "[smoke-app]", "installed live config check")

        down = run(control_script_command(install_dir, "down"), cwd=workdir, env=env)
        if docker_managed_install():
            require_contains(completed_output(down), "[DEPLOYED : smoke-app] down... done", "installed control down")
        require_not_contains(completed_output(down), "[smoke-app]", "installed control down")
    finally:
        if installed or install_dir.exists():
            run(
                [str(reploy), "uninstall", "--from", str(install_dir), "--remove-dir"],
                cwd=workdir,
                env=env,
            )
        if install_dir.exists():
            raise SystemExit(f"persistent install cleanup left target directory behind: {install_dir}")


def run_smoke(
    reploy: Path,
    workdir: Path,
    *,
    plan_only: bool,
    runtime: bool,
    persistent_install: bool,
    docker_mode: str,
    color: bool,
) -> None:
    repo_root = Path(__file__).resolve().parents[2]
    pack_dir = repo_root / "tests" / "e2e" / "python" / "packages" / "smoke-blueprint"
    deploy_dir = workdir / "deployment"
    install_dir = workdir / "installed"
    if not (pack_dir / "smoke.blueprint.yaml").is_file():
        raise SystemExit(f"missing e2e smoke blueprint: {pack_dir}")

    env = os.environ.copy()
    if color:
        env.pop("NO_COLOR", None)
        env.pop("CI", None)
        env["REPLOY_COLOR"] = "always"
        env["TERM"] = "xterm-256color"
        env["COLORTERM"] = "truecolor"
    else:
        env["NO_COLOR"] = "1"
        env["TERM"] = "dumb"

    docker_enabled = docker_mode != "skip"
    if docker_enabled and not plan_only:
        available, reason = docker_available(env, workdir)
        if not available:
            if docker_mode == "optional":
                docker_enabled = False
            else:
                raise SystemExit(f"Docker is required for this smoke test: {reason}")

    init = run(
        [str(reploy), "stage", "file:" + str(pack_dir), "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    require_contains(init.stdout, "created staging directory", "stage output")

    update = run(
        [str(reploy), "stage", "--update", "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    if "up_to_date" not in update.stdout and ".reploy/state.json" not in update.stdout:
        raise SystemExit(
            "update output did not report an unchanged or updated deployment"
            f"\n--- output ---\n{update.stdout}"
        )

    info = run([str(reploy), "info", "--dir", str(deploy_dir)], cwd=workdir, env=env)
    require_contains(info.stdout, "phase: staged", "info output")
    require_contains(info.stdout, "python package smoke-suite", "info output")

    options = run(
        [str(reploy), "bundle", "list-options", "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    require_contains(options.stdout, "imap\tInstall the smoke IMAP plugin.", "bundle options")

    add = run(
        [str(reploy), "bundle", "add", "--name", "imap", "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    require_contains(add.stdout, "updated", "bundle add output")

    bundle_list = run([str(reploy), "bundle", "list", "--dir", str(deploy_dir)], cwd=workdir, env=env)
    require_contains(bundle_list.stdout, "smoke-suite", "bundle list")
    require_contains(bundle_list.stdout, "smoke-imap", "bundle list")

    if plan_only or not docker_enabled:
        bundle_build = run(
            [str(reploy), "bundle", "build", "--dry-run", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(bundle_build.stdout, "would build installation bundle:", "bundle build dry-run")
        require_contains(bundle_build.stdout, "docker run --rm", "bundle build dry-run")
    else:
        bundle_build = run(
            [str(reploy), "bundle", "build", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(bundle_build.stderr, "building installation bundle... done", "bundle build")
        bundle_check = run(
            [str(reploy), "bundle", "check", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(bundle_check.stderr, "validating installation bundle... done", "bundle check")
        bundle_all = run(
            [str(reploy), "bundle", "list", "all", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(bundle_all.stdout, "root\tsmoke-suite==0.1.0", "bundle list all")
        require_contains(bundle_all.stdout, "root\tsmoke-imap==0.1.0", "bundle list all")
        if runtime:
            run_runtime_smoke(reploy, deploy_dir, workdir, env)

    if not docker_enabled:
        return

    doctor = run(
        [str(reploy), "doctor", "--preinstall", "--scope", install_scope(), "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    require_contains(completed_output(doctor), "ok: preinstall checks passed", "preinstall doctor")

    install = run(
        [
            str(reploy),
            "install",
            "--dir",
            str(deploy_dir),
            "--to",
            str(install_dir),
            "--scope",
            install_scope(),
            "--service",
            "smoke-e2e",
            "--port",
            "18082",
            "--dry-run",
        ],
        cwd=workdir,
        env=env,
    )
    require_contains(install.stdout, "would install deployment:", "install dry-run")
    require_prefixed_lines(install.stdout, "[STAGING : smoke-app] ", "install dry-run")
    require_contains(install.stdout, "[STAGING : smoke-app] would install deployment:", "install dry-run")
    require_contains(install.stdout, "service: smoke-e2e", "install dry-run")
    require_contains(install.stdout, "port https: 127.0.0.1:18082 -> 19075", "install dry-run")
    require_contains(
        install.stdout,
        "would rebuild local source bundle: smoke-imap, smoke-suite",
        "install dry-run",
    )
    require_contains(install.stdout, "would run before start hook: app config check", "install dry-run")
    require_contains(install.stdout, "would run after start hook: health check --wait", "install dry-run")
    require_contains(install.stdout, "would print success line: server url: ${server_url}", "install dry-run")

    if not plan_only:
        if persistent_install:
            run_persistent_install_smoke(reploy, deploy_dir, install_dir, workdir, env)

        run([str(reploy), "bundle", "clean", "--dir", str(deploy_dir)], cwd=workdir, env=env)

    if not docker_managed_install():
        run([str(reploy), "services", "list"], cwd=workdir, env=env)


def main() -> int:
    args = parse_args()
    reploy = Path(args.reploy).resolve()
    if not reploy.is_file():
        raise SystemExit(f"missing reploy binary: {reploy}")
    if not os.access(reploy, os.X_OK):
        raise SystemExit(f"reploy binary is not executable: {reploy}")

    if args.keep_workdir:
        workdir = make_workdir()
        print(f"workdir: {workdir}")
        run_smoke(
            reploy,
            workdir,
            plan_only=args.plan_only,
            runtime=args.runtime,
            persistent_install=args.persistent_install,
            docker_mode=args.docker_mode,
            color=args.color,
        )
    else:
        workdir = make_workdir()
        try:
            run_smoke(
                reploy,
                workdir,
                plan_only=args.plan_only,
                runtime=args.runtime,
                persistent_install=args.persistent_install,
                docker_mode=args.docker_mode,
                color=args.color,
            )
        finally:
            shutil.rmtree(workdir, ignore_errors=True)
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except SmokeInterrupted as error:
        print(f"[smoke] {error}", file=sys.stderr)
        raise SystemExit(INTERRUPT_EXIT_CODE) from None
    except KeyboardInterrupt:
        print("[smoke] interrupted", file=sys.stderr)
        raise SystemExit(INTERRUPT_EXIT_CODE) from None
