#!/usr/bin/env python3
"""Exercise the Reploy CLI against a real temporary deployment."""

from __future__ import annotations

import argparse
import codecs
import os
import re
import shutil
import socket
import subprocess
import sys
import tempfile
import threading
import time
from pathlib import Path
from typing import NamedTuple

ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
INTERRUPT_EXIT_CODE = 130


class StreamCapture(NamedTuple):
    stdout_chunks: list[str]
    stderr_chunks: list[str]
    threads: list[threading.Thread]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--reploy",
        required=True,
        help="Path to the reploy binary to exercise.",
    )
    parser.add_argument(
        "--keep-workdir",
        action="store_true",
        help="Keep the temporary smoke work directory for debugging.",
    )
    parser.add_argument(
        "--workdir",
        help=(
            "Use this work directory instead of creating a temporary one. "
            "The directory must be absent or empty."
        ),
    )
    parser.add_argument(
        "--color",
        action="store_true",
        help="Force color output and use a smart terminal identity.",
    )
    parser.add_argument(
        "--plan-only",
        action="store_true",
        help=(
            "Skip the Docker-backed bundle build/check/list-all while still "
            "running preinstall and install dry-run checks."
        ),
    )
    parser.add_argument(
        "--no-docker",
        action="store_true",
        help="Exercise staging and bundle planning without executing Docker, preinstall, or install checks.",
    )
    parser.add_argument(
        "--runtime",
        action="store_true",
        help="Include the live staging runtime lifecycle: up/status/logs/test/down.",
    )
    parser.add_argument(
        "--persistent-install",
        action="store_true",
        help="Include Docker-managed persistent install/control/uninstall checks.",
    )
    parser.add_argument(
        "--verbose-bundle",
        action="store_true",
        help="Run bundle build in verbose mode so Reploy prints its phase timing breakdown.",
    )
    parser.add_argument(
        "--runtime-volume",
        action="store_true",
        help="Use a temporary Docker named volume for the generated Python runtime cache.",
    )
    parser.add_argument(
        "--runtime-host-dir",
        action="store_true",
        help="Use a temporary explicit host directory for the generated Python runtime cache.",
    )
    parser.add_argument(
        "--docker-mode",
        choices=("required", "optional", "skip"),
        default="required",
        help="Control Docker-backed smoke phases. Defaults to required.",
    )
    parser.add_argument(
        "--port-conflict-probe",
        action="store_true",
        help="After bundle build/check, verify a staging up fails cleanly when the host port is already occupied.",
    )
    parser.add_argument(
        "--docker-unavailable-probe",
        action="store_true",
        help="Verify preinstall doctor fails cleanly when Docker Desktop is unavailable.",
    )
    args = parser.parse_args()
    if args.no_docker:
        if args.docker_mode != "required":
            parser.error("--no-docker cannot be combined with --docker-mode")
        args.docker_mode = "skip"
    if args.runtime and args.plan_only:
        parser.error("--runtime cannot be combined with --plan-only")
    if args.runtime and args.docker_mode != "required":
        parser.error("--runtime requires Docker and cannot be combined with --no-docker or optional Docker mode")
    if args.persistent_install and args.plan_only:
        parser.error("--persistent-install cannot be combined with --plan-only")
    if args.persistent_install and args.docker_mode != "required":
        parser.error(
            "--persistent-install requires Docker and cannot be combined "
            "with --no-docker or optional Docker mode"
        )
    if args.runtime_volume and args.runtime_host_dir:
        parser.error("--runtime-volume cannot be combined with --runtime-host-dir")
    if args.port_conflict_probe and args.docker_unavailable_probe:
        parser.error("--port-conflict-probe cannot be combined with --docker-unavailable-probe")
    if args.port_conflict_probe and args.docker_mode != "required":
        parser.error("--port-conflict-probe requires Docker and cannot be combined with --no-docker or optional Docker mode")
    if args.docker_unavailable_probe and (args.runtime or args.persistent_install):
        parser.error("--docker-unavailable-probe cannot be combined with --runtime or --persistent-install")
    if args.docker_unavailable_probe and args.docker_mode != "required":
        parser.error("--docker-unavailable-probe cannot be combined with --no-docker or optional Docker mode")
    return args


def run(argv: list[str], *, cwd: Path, env: dict[str, str]) -> subprocess.CompletedProcess[str]:
    print("+ " + " ".join(argv), flush=True)
    started = time.monotonic()
    completed = subprocess.Popen(
        argv,
        cwd=cwd,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    stdout_chunks: list[str] = []
    stderr_chunks: list[str] = []
    output_lock = threading.Lock()

    def safe_write(target, content: str) -> None:
        try:
            target.write(content)
            target.flush()
        except UnicodeEncodeError:
            encoding = getattr(target, "encoding", None) or "utf-8"
            buffer = getattr(target, "buffer", None)
            if buffer is None:
                target.write(content.encode(encoding, errors="replace").decode(encoding, errors="replace"))
                target.flush()
                return
            buffer.write(content.encode(encoding, errors="replace"))
            buffer.flush()

    def stream_pipe(pipe, target, chunks: list[str]) -> None:
        assert pipe is not None
        decoder = codecs.getincrementaldecoder("utf-8")(errors="replace")
        display_buffer = ""

        def display(content: str, *, final: bool = False) -> None:
            nonlocal display_buffer
            display_buffer += content
            while True:
                newline = display_buffer.find("\n")
                if newline == -1:
                    break
                line = display_buffer[: newline + 1]
                display_buffer = display_buffer[newline + 1 :]
                with output_lock:
                    safe_write(target, line)
            if final and display_buffer:
                with output_lock:
                    safe_write(target, display_buffer)
                display_buffer = ""

        while True:
            data = os.read(pipe.fileno(), 65536)
            if data == b"":
                break
            content = decoder.decode(data)
            if content == "":
                continue
            chunks.append(content)
            display(content)
        remainder = decoder.decode(b"", final=True)
        if remainder:
            chunks.append(remainder)
            display(remainder)
        display("", final=True)

    threads = [
        threading.Thread(target=stream_pipe, args=(completed.stdout, sys.stdout, stdout_chunks)),
        threading.Thread(target=stream_pipe, args=(completed.stderr, sys.stderr, stderr_chunks)),
    ]
    for thread in threads:
        thread.start()
    capture = StreamCapture(stdout_chunks, stderr_chunks, threads)
    try:
        returncode = completed.wait()
    except KeyboardInterrupt:
        terminate_child(completed)
        join_streams(capture)
        raise SmokeInterrupted(f"interrupted while running: {' '.join(argv)}") from None
    join_streams(capture)
    if returncode != 0:
        raise SystemExit(f"[smoke] command failed with exit code {returncode}: {' '.join(argv)}")
    print(f"[smoke] command elapsed: {format_duration(time.monotonic() - started)}", flush=True)
    return subprocess.CompletedProcess(
        argv,
        returncode,
        stdout="".join(stdout_chunks),
        stderr="".join(stderr_chunks),
    )


def run_expect_failure(
    argv: list[str],
    *,
    cwd: Path,
    env: dict[str, str],
    context: str,
) -> subprocess.CompletedProcess[str]:
    print("+ " + " ".join(argv), flush=True)
    started = time.monotonic()
    completed = subprocess.run(
        argv,
        cwd=cwd,
        env=env,
        text=True,
        encoding="utf-8",
        errors="replace",
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.stdout:
        sys.stdout.write(completed.stdout)
        sys.stdout.flush()
    if completed.stderr:
        sys.stderr.write(completed.stderr)
        sys.stderr.flush()
    if completed.returncode == 0:
        raise SystemExit(f"[smoke] {context} unexpectedly succeeded: {' '.join(argv)}")
    print(
        f"[smoke] expected failure observed for {context}: "
        f"exit {completed.returncode}, elapsed {format_duration(time.monotonic() - started)}",
        flush=True,
    )
    return completed


def format_duration(seconds: float) -> str:
    if seconds < 10:
        return f"{seconds:.2f}s"
    return f"{seconds:.1f}s"


class SmokeInterrupted(Exception):
    pass


def terminate_child(process: subprocess.Popen[bytes]) -> None:
    if process.poll() is not None:
        return
    process.terminate()
    try:
        process.wait(timeout=5)
    except subprocess.TimeoutExpired:
        process.kill()
        process.wait(timeout=5)


def join_streams(capture: StreamCapture) -> None:
    for thread in capture.threads:
        thread.join(timeout=5)


def require_contains(output: str, needle: str, context: str) -> None:
    if needle not in strip_ansi(output):
        raise SystemExit(f"[smoke] {context} did not contain {needle!r}\n--- output ---\n{output}")


def require_not_contains(output: str, needle: str, context: str) -> None:
    if needle in strip_ansi(output):
        raise SystemExit(f"[smoke] {context} unexpectedly contained {needle!r}\n--- output ---\n{output}")


def require_prefixed_lines(output: str, prefix: str, context: str) -> None:
    stripped = strip_ansi(output)
    unprefixed = [line for line in stripped.splitlines() if line.strip() and not line.startswith(prefix)]
    if unprefixed:
        detail = "\n".join(unprefixed[:5])
        raise SystemExit(
            f"[smoke] {context} contained unprefixed line(s); expected {prefix!r}\n"
            f"--- unprefixed ---\n{detail}\n--- output ---\n{output}"
        )


def strip_ansi(value: str) -> str:
    return ANSI_ESCAPE_RE.sub("", value)


def completed_output(completed: subprocess.CompletedProcess[str]) -> str:
    return completed.stdout + completed.stderr


def upsert_env_value(path: Path, key: str, value: str) -> None:
    prefix = key + "="
    lines = path.read_text(encoding="utf-8").splitlines()
    updated = False
    for index, line in enumerate(lines):
        if line.startswith(prefix):
            lines[index] = prefix + value
            updated = True
            break
    if not updated:
        lines.append(prefix + value)
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def docker_volume_name(value: str) -> str:
    normalized = re.sub(r"[^A-Za-z0-9_.-]+", "-", value).strip("-")
    return normalized or "reploy-smoke-runtime"


def is_docker_named_volume_reference(value: str) -> bool:
    value = value.strip()
    if value in {"", ".", ".."}:
        return False
    if value.startswith(".") or any(separator in value for separator in ("/", "\\", ":")):
        return False
    return re.fullmatch(r"[A-Za-z0-9_.-]+", value) is not None


def runtime_volume_from_deployment(deploy_dir: Path) -> str:
    docker_env = deploy_dir / ".reploy" / "docker.env"
    if not docker_env.is_file():
        return ""
    prefix = "REPLOY_RUNTIME_DIR="
    for line in docker_env.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if line.startswith(prefix):
            value = line[len(prefix) :].strip()
            return value if is_docker_named_volume_reference(value) else ""
    return ""


def enable_runtime_volume(deploy_dir: Path, volume_name: str) -> None:
    upsert_env_value(deploy_dir / ".reploy" / "docker.env", "REPLOY_RUNTIME_DIR", volume_name)
    compose_path = deploy_dir / ".reploy" / "runtime" / "compose.yaml"
    compose = compose_path.read_text(encoding="utf-8")
    if "\nvolumes:\n" not in compose:
        compose += "\nvolumes:\n"
    if f"  {volume_name}:\n" not in compose:
        compose += f"  {volume_name}:\n    name: {volume_name}\n    external: true\n"
    compose_path.write_text(compose, encoding="utf-8")


def enable_runtime_host_dir(deploy_dir: Path, runtime_dir: Path) -> None:
    runtime_dir.mkdir(parents=True, exist_ok=True)
    relative = runtime_dir.relative_to(deploy_dir)
    upsert_env_value(deploy_dir / ".reploy" / "docker.env", "REPLOY_RUNTIME_DIR", "./" + relative.as_posix())


def cleanup_docker_volume(name: str, *, cwd: Path, env: dict[str, str]) -> None:
    if not name:
        return
    if shutil.which("docker") is None:
        return
    available, _ = docker_available(env, cwd)
    if not available:
        return
    completed = subprocess.run(
        ["docker", "volume", "rm", "-f", name],
        cwd=cwd,
        env=env,
        text=True,
        encoding="utf-8",
        errors="replace",
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode != 0:
        detail = (completed.stderr or completed.stdout).strip()
        if "No such volume" not in detail:
            print(f"[smoke] warning: failed to remove Docker volume {name}: {detail}", file=sys.stderr)


def cleanup_runtime_volume_from_deployment(deploy_dir: Path, *, cwd: Path, env: dict[str, str]) -> None:
    cleanup_docker_volume(runtime_volume_from_deployment(deploy_dir), cwd=cwd, env=env)


def finish_smoke(reploy: Path, workdir: Path, deploy_dir: Path, env: dict[str, str], started: float) -> None:
    run([str(reploy), "--version"], cwd=workdir, env=env)
    print(f"[smoke] measured elapsed: {format_duration(time.monotonic() - started)}", flush=True)
    cleanup_runtime_volume_from_deployment(deploy_dir, cwd=workdir, env=env)


def docker_available(env: dict[str, str], cwd: Path) -> tuple[bool, str]:
    if shutil.which("docker") is None:
        return False, "docker command not found"
    try:
        completed = subprocess.run(
            ["docker", "info"],
            cwd=cwd,
            env=env,
            text=True,
            encoding="utf-8",
            errors="replace",
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=20,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return False, "docker info timed out"
    if completed.returncode != 0:
        detail = (completed.stderr or completed.stdout).strip()
        if detail:
            return False, detail
        return False, f"docker info failed with exit code {completed.returncode}"
    return True, ""


def free_local_port() -> str:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as listener:
        listener.bind(("127.0.0.1", 0))
        return str(listener.getsockname()[1])


def install_scope() -> str:
    return "user"


def docker_managed_install() -> bool:
    return install_scope() == "user"


def control_script_command(install_dir: Path, *args: str) -> list[str]:
    if sys.platform.startswith(("win32", "cygwin", "msys")):
        script = install_dir / "smoke-appctl.ps1"
        return [
            "powershell",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            str(script),
            *args,
        ]
    return [str(install_dir / "smoke-appctl"), *args]


def update_env_file(path: Path, updates: dict[str, str]) -> None:
    lines = path.read_text().splitlines()
    remaining = dict(updates)
    rewritten: list[str] = []
    for line in lines:
        key, separator, _ = line.partition("=")
        if separator and key in remaining:
            rewritten.append(f"{key}={remaining.pop(key)}")
        else:
            rewritten.append(line)
    for key, value in remaining.items():
        rewritten.append(f"{key}={value}")
    path.write_text("\n".join(rewritten) + "\n")


def make_workdir(path: str | None = None) -> Path:
    if path is None:
        return Path(tempfile.mkdtemp(prefix="reploy-e2e-smoke-"))
    workdir = Path(path)
    if workdir.exists() and any(workdir.iterdir()):
        raise SystemExit(f"--workdir must be absent or empty: {workdir}")
    workdir.mkdir(parents=True, exist_ok=True)
    (workdir / ".reploy-smoke-workdir").write_text("created by tools/e2e/smoke\n", encoding="utf-8")
    return workdir


def cleanup_workdir(workdir: Path) -> None:
    marker = workdir / ".reploy-smoke-workdir"
    if marker.exists():
        shutil.rmtree(workdir, ignore_errors=True)
        return
    if workdir.name.startswith("reploy-e2e-smoke-"):
        shutil.rmtree(workdir, ignore_errors=True)


def run_docker_unavailable_probe(reploy: Path, deploy_dir: Path, workdir: Path, env: dict[str, str]) -> None:
    doctor = run_expect_failure(
        [str(reploy), "doctor", "--preinstall", "--scope", install_scope(), "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
        context="Docker unavailable preinstall doctor",
    )
    output = completed_output(doctor)
    require_contains(output, "Docker Desktop runtime is required", "Docker unavailable preinstall doctor")


def run_port_conflict_probe(reploy: Path, deploy_dir: Path, workdir: Path, env: dict[str, str]) -> None:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as listener:
        listener.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        listener.bind(("127.0.0.1", 18075))
        listener.listen(1)
        occupied_port = str(listener.getsockname()[1])
        try:
            up = run_expect_failure(
                [str(reploy), "up", "--dir", str(deploy_dir)],
                cwd=workdir,
                env=env,
                context=f"port conflict on 127.0.0.1:{occupied_port}",
            )
        finally:
            subprocess.run(
                [str(reploy), "down", "--dir", str(deploy_dir)],
                cwd=workdir,
                env=env,
                text=True,
                encoding="utf-8",
                errors="replace",
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
            )
    require_contains(completed_output(up).lower(), "port", "port conflict output")


def run_runtime_smoke(reploy: Path, deploy_dir: Path, workdir: Path, env: dict[str, str]) -> None:
    # Staging publication is blueprint-owned in the environment model. Installed
    # publication remains overridable through `reploy install --port` below.
    host_port = "18075"

    primary_error: BaseException | None = None
    started = False
    try:
        if os.name == "posix":
            run(
                [
                    sys.executable,
                    str(Path(__file__).with_name("shell_pty.py")),
                    "--reploy",
                    str(reploy),
                    "--dir",
                    str(deploy_dir),
                ],
                cwd=workdir,
                env=env,
            )

        app_check = run(
            [str(reploy), "app", "config", "check", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(app_check.stdout, '"check": "pass"', "config check")

        run([str(reploy), "up", "--dir", str(deploy_dir)], cwd=workdir, env=env)
        started = True

        run([str(reploy), "status", "--dir", str(deploy_dir)], cwd=workdir, env=env)
        health = run(
            [str(reploy), "test", "--timeout", "30s", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(health.stdout, f"ok: https://127.0.0.1:{host_port}/_health_", "health check")

        logs = run(
            [str(reploy), "logs", "--tail", "50", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(logs.stdout, "smoke-suite serving HTTPS", "runtime logs")

        live_check = run(
            [str(reploy), "app", "config", "check", "--live", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(live_check.stdout, '"check": "pass"', "live config check")

        run([str(reploy), "restart", "--dir", str(deploy_dir)], cwd=workdir, env=env)
        restarted_health = run(
            [str(reploy), "test", "--timeout", "30s", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(restarted_health.stdout, f"ok: https://127.0.0.1:{host_port}/_health_", "health check after restart")
    except BaseException as error:
        primary_error = error
        raise
    finally:
        if started:
            try:
                run([str(reploy), "down", "--dir", str(deploy_dir)], cwd=workdir, env=env)
            except BaseException as cleanup_error:
                if primary_error is None:
                    raise
                print(f"[smoke] warning: runtime cleanup failed after earlier error: {cleanup_error}", file=sys.stderr)


def run_persistent_install_smoke(
    reploy: Path,
    deploy_dir: Path,
    install_dir: Path,
    workdir: Path,
    env: dict[str, str],
) -> None:
    install_port = free_local_port()
    installed = False
    try:
        install = run(
            [
                str(reploy),
                "install",
                "--dir",
                str(deploy_dir),
                "--to",
                str(install_dir),
                "--scope",
                install_scope(),
                "--port",
                install_port,
            ],
            cwd=workdir,
            env=env,
        )
        installed = True
        require_contains(install.stdout, f"server url: https://127.0.0.1:{install_port}", "install output")

        status = run(control_script_command(install_dir, "status"), cwd=workdir, env=env)
        require_contains(completed_output(status), "smoke-app", "installed control status")
        if docker_managed_install():
            require_contains(status.stdout, "[DEPLOYED : smoke-app] NAME", "installed control status")
        else:
            require_contains(completed_output(status), "[DEPLOYED : smoke-app]", "installed control status")
        require_not_contains(completed_output(status), "[smoke-app]", "installed control status")

        logs = run(control_script_command(install_dir, "logs"), cwd=workdir, env=env)
        require_contains(completed_output(logs), "smoke-suite serving HTTPS", "installed control logs")
        require_not_contains(completed_output(logs), "[smoke-app]", "installed control logs")

        live_check = run(control_script_command(install_dir, "config", "check", "--live"), cwd=workdir, env=env)
        require_contains(completed_output(live_check), '"check": "pass"', "installed live config check")
        require_not_contains(completed_output(live_check), "[smoke-app]", "installed live config check")

        down = run(control_script_command(install_dir, "down"), cwd=workdir, env=env)
        if docker_managed_install():
            require_contains(completed_output(down), "[DEPLOYED : smoke-app] down... done", "installed control down")
        require_not_contains(completed_output(down), "[smoke-app]", "installed control down")
    finally:
        if installed or install_dir.exists():
            run(
                [str(reploy), "uninstall", "--from", str(install_dir), "--remove-dir"],
                cwd=workdir,
                env=env,
            )
        if install_dir.exists():
            raise SystemExit(f"persistent install cleanup left target directory behind: {install_dir}")


def run_smoke(
    reploy: Path,
    workdir: Path,
    *,
    plan_only: bool,
    runtime: bool,
    persistent_install: bool,
    docker_mode: str,
    color: bool,
    verbose_bundle: bool,
    runtime_volume: bool,
    runtime_host_dir: bool,
    port_conflict_probe: bool,
    docker_unavailable_probe: bool,
) -> None:
    repo_root = Path(__file__).resolve().parents[2]
    packages_dir = repo_root / "tests" / "e2e" / "python" / "packages"
    pack_dir = packages_dir / "smoke-blueprint"
    deploy_dir = workdir / "deployment"
    install_dir = workdir / "installed"
    if not (pack_dir / "smoke.blueprint.yaml").is_file():
        raise SystemExit(f"missing e2e smoke blueprint: {pack_dir}")

    env = os.environ.copy()
    if color:
        env.pop("NO_COLOR", None)
        env.pop("CI", None)
        env["REPLOY_COLOR"] = "always"
        env["TERM"] = "xterm-256color"
        env["COLORTERM"] = "truecolor"
    else:
        env["NO_COLOR"] = "1"
        env["TERM"] = "dumb"

    run([str(reploy), "--version"], cwd=workdir, env=env)

    if sys.platform == "win32":
        fixture_dir = workdir / "fixture-packages"
        copy_started = time.monotonic()
        shutil.copytree(packages_dir, fixture_dir)
        print(f"[smoke] Windows fixture copy elapsed: {format_duration(time.monotonic() - copy_started)}", flush=True)
        pack_dir = fixture_dir / "smoke-blueprint"
    smoke_started = time.monotonic()

    docker_enabled = docker_mode != "skip"
    if docker_unavailable_probe:
        docker_enabled = True
    if docker_enabled and not plan_only and not docker_unavailable_probe:
        available, reason = docker_available(env, workdir)
        if not available:
            if docker_mode == "optional":
                docker_enabled = False
            else:
                raise SystemExit(f"Docker is required for this smoke test: {reason}")

    runtime_volume_name = ""
    if runtime_volume:
        runtime_volume_name = docker_volume_name(workdir.name + "-runtime")
    runtime_host_path = deploy_dir / ".reploy" / "runtime-host" if runtime_host_dir else None

    init = run(
        [str(reploy), "stage", "file:" + str(pack_dir), "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    require_contains(init.stdout, "created staging directory", "stage output")

    update = run(
        [str(reploy), "stage", "--update", "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    update_markers = ("up_to_date", ".reploy/state.json", "updated staging directory")
    if not any(marker in update.stdout for marker in update_markers):
        raise SystemExit(
            "update output did not report an unchanged or updated deployment"
            f"\n--- output ---\n{update.stdout}"
        )

    if docker_unavailable_probe:
        run_docker_unavailable_probe(reploy, deploy_dir, workdir, env)
        finish_smoke(reploy, workdir, deploy_dir, env, smoke_started)
        return

    info = run([str(reploy), "info", "--dir", str(deploy_dir)], cwd=workdir, env=env)
    require_contains(info.stdout, "phase: staged", "info output")
    require_contains(info.stdout, "python package smoke-suite", "info output")

    options = run(
        [str(reploy), "bundle", "list-options", "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    require_contains(options.stdout, "imap\tInstall the smoke IMAP plugin.", "bundle options")

    add = run(
        [str(reploy), "bundle", "add", "--name", "imap", "--dir", str(deploy_dir)],
        cwd=workdir,
        env=env,
    )
    require_contains(add.stdout, "updated", "bundle add output")
    if runtime_volume_name:
        enable_runtime_volume(deploy_dir, runtime_volume_name)
        print(f"[smoke] Docker runtime volume: {runtime_volume_name}", flush=True)
    if runtime_host_path is not None:
        enable_runtime_host_dir(deploy_dir, runtime_host_path)
        print(f"[smoke] host runtime mount: {runtime_host_path}", flush=True)

    bundle_list = run([str(reploy), "bundle", "list", "--dir", str(deploy_dir)], cwd=workdir, env=env)
    require_contains(bundle_list.stdout, "smoke-suite", "bundle list")
    require_contains(bundle_list.stdout, "smoke-imap", "bundle list")

    if plan_only or not docker_enabled:
        bundle_build = run(
            [str(reploy), "bundle", "build", "--dry-run", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(bundle_build.stdout, "would build installation bundle:", "bundle build dry-run")
        require_contains(bundle_build.stdout, "docker run --rm", "bundle build dry-run")
    else:
        bundle_build_args = [str(reploy), "bundle", "build", "--dir", str(deploy_dir)]
        if verbose_bundle:
            bundle_build_args.insert(3, "--verbose")
        bundle_build = run(
            bundle_build_args,
            cwd=workdir,
            env=env,
        )
        if verbose_bundle:
            require_contains(completed_output(bundle_build), "bundle build timing:", "bundle build")
        else:
            require_contains(bundle_build.stderr, "building installation bundle... done", "bundle build")
        bundle_check = run(
            [str(reploy), "bundle", "check", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(bundle_check.stderr, "validating installation bundle... done", "bundle check")
        bundle_all = run(
            [str(reploy), "bundle", "list", "all", "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(bundle_all.stdout, "root\tsmoke-suite==0.1.0", "bundle list all")
        require_contains(bundle_all.stdout, "root\tsmoke-imap==0.1.0", "bundle list all")
        if runtime:
            run_runtime_smoke(reploy, deploy_dir, workdir, env)
        if port_conflict_probe:
            run_port_conflict_probe(reploy, deploy_dir, workdir, env)
            finish_smoke(reploy, workdir, deploy_dir, env, smoke_started)
            return

    if not docker_enabled:
        finish_smoke(reploy, workdir, deploy_dir, env, smoke_started)
        return

    install_checks = plan_only or persistent_install or not runtime
    if install_checks:
        doctor = run(
            [str(reploy), "doctor", "--preinstall", "--scope", install_scope(), "--dir", str(deploy_dir)],
            cwd=workdir,
            env=env,
        )
        require_contains(completed_output(doctor), "ok: preinstall checks passed", "preinstall doctor")

        install = run(
            [
                str(reploy),
                "install",
                "--dir",
                str(deploy_dir),
                "--to",
                str(install_dir),
                "--scope",
                install_scope(),
                "--service",
                "smoke-e2e",
                "--port",
                "18082",
                "--dry-run",
            ],
            cwd=workdir,
            env=env,
        )
        require_contains(install.stdout, "would install deployment:", "install dry-run")
        require_prefixed_lines(install.stdout, "[STAGING : smoke-app] ", "install dry-run")
        require_contains(install.stdout, "[STAGING : smoke-app] would install deployment:", "install dry-run")
        require_contains(install.stdout, "service: smoke-e2e", "install dry-run")
        require_contains(install.stdout, "port https: 127.0.0.1:18082 -> 8075", "install dry-run")
        require_contains(
            install.stdout,
            "would rebuild local source bundle: smoke-imap, smoke-suite",
            "install dry-run",
        )
        require_contains(install.stdout, "would run environment before_start lifecycle: 1 step(s)", "install dry-run")
        require_contains(
            install.stdout,
            "would satisfy readiness and run environment after_start lifecycle: 1 step(s)",
            "install dry-run",
        )

    if not plan_only:
        if persistent_install:
            run_persistent_install_smoke(reploy, deploy_dir, install_dir, workdir, env)

        run([str(reploy), "bundle", "clean", "--dir", str(deploy_dir)], cwd=workdir, env=env)

    if not docker_managed_install():
        run([str(reploy), "services", "list"], cwd=workdir, env=env)
    finish_smoke(reploy, workdir, deploy_dir, env, smoke_started)


def main() -> int:
    args = parse_args()
    reploy = Path(args.reploy).resolve()
    if not reploy.is_file():
        raise SystemExit(f"missing reploy binary: {reploy}")
    if not os.access(reploy, os.X_OK):
        raise SystemExit(f"reploy binary is not executable: {reploy}")

    if args.keep_workdir:
        workdir = make_workdir(args.workdir)
        print(f"workdir: {workdir}")
        run_smoke(
            reploy,
            workdir,
            plan_only=args.plan_only,
            runtime=args.runtime,
            persistent_install=args.persistent_install,
            docker_mode=args.docker_mode,
            color=args.color,
            verbose_bundle=args.verbose_bundle,
            runtime_volume=args.runtime_volume,
            runtime_host_dir=args.runtime_host_dir,
            port_conflict_probe=args.port_conflict_probe,
            docker_unavailable_probe=args.docker_unavailable_probe,
        )
    else:
        workdir = make_workdir(args.workdir)
        try:
            run_smoke(
                reploy,
                workdir,
                plan_only=args.plan_only,
                runtime=args.runtime,
                persistent_install=args.persistent_install,
                docker_mode=args.docker_mode,
                color=args.color,
                verbose_bundle=args.verbose_bundle,
                runtime_volume=args.runtime_volume,
                runtime_host_dir=args.runtime_host_dir,
                port_conflict_probe=args.port_conflict_probe,
                docker_unavailable_probe=args.docker_unavailable_probe,
            )
        finally:
            cleanup_runtime_volume_from_deployment(workdir / "deployment", cwd=workdir, env=os.environ.copy())
            cleanup_workdir(workdir)
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except SmokeInterrupted as error:
        print(f"[smoke] {error}", file=sys.stderr)
        raise SystemExit(INTERRUPT_EXIT_CODE) from None
    except KeyboardInterrupt:
        print("[smoke] interrupted", file=sys.stderr)
        raise SystemExit(INTERRUPT_EXIT_CODE) from None
